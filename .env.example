# AdjudiCLAIMS Environment Variables
# Copy to .env and fill in values
# NEVER commit .env to git — secrets come from GCP Secret Manager in production

# Database
DATABASE_URL=postgresql://adjudiclaims:password@localhost:5442/adjudiclaims

# Server
NODE_ENV=development
PORT=4901
SESSION_SECRET=change-me-in-production-min-32chars!

# AI Services (optional in dev — services degrade gracefully)
ANTHROPIC_API_KEY=sk-ant-xxx
VERTEX_AI_PROJECT=adjudiclaims-staging
DOCUMENT_AI_PROCESSOR=projects/xxx/locations/us/processors/xxx
GCS_BUCKET=adjudiclaims-staging

# CORS (comma-separated origins, omit for allow-all in dev)
# CORS_ORIGINS=http://localhost:4900

# Temporal (reuse existing server in dev, Temporal Cloud in prod)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=adjudiclaims
# TEMPORAL_API_KEY=               # Set for Temporal Cloud (enables TLS)

# Sentry (optional in dev — set DSN to enable error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=                 # Set to git SHA in CI/CD
