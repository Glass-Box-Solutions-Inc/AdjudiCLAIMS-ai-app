{
  "name": "adjudiclaims-ai-app",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "AdjudiCLAIMS - AI-powered workers' compensation claims analysis platform",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:upl": "vitest run --config vitest.config.upl.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts && vitest run --config vitest.config.upl.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.0.1",
    "@google-cloud/aiplatform": "^6.5.0",
    "@google-cloud/documentai": "^9.6.0",
    "@google-cloud/storage": "^7.19.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.4.1",
    "@react-router/node": "^7.3.0",
    "@react-router/serve": "^7.3.0",
    "@tanstack/react-query": "^5.95.2",
    "better-auth": "^1.5.6",
    "fastify": "^5.2.1",
    "isbot": "^5.1.22",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-router": "^7.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.5.3",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.7"
  }
}
