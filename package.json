{
  "name": "adjudiclaims-ai-app",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "AdjudiCLAIMS - AI-powered workers' compensation claims analysis platform",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:upl": "vitest run --config vitest.config.upl.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts && vitest run --config vitest.config.upl.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/session": "^11.0.1",
    "@prisma/client": "^6.4.1",
    "@react-router/node": "^7.3.0",
    "@react-router/serve": "^7.3.0",
    "fastify": "^5.2.1",
    "isbot": "^5.1.22",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.3.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.3.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vitest": "^3.0.7"
  }
}
